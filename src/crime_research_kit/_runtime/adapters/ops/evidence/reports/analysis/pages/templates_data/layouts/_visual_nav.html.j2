<header class="crk-topbar">
<button class="crk-nav-toggle" type="button" data-crk-nav-toggle aria-controls="crk-visual-sidebar" aria-expanded="true">
<span class="crk-hamburger" aria-hidden="true"></span>
<span class="crk-sr-only">Toggle navigation</span>
</button>
<div class="crk-topbar-title">
<strong>{{ page_title }}</strong>
<span data-crk-scope>{{ package.scope }}</span>
</div>
</header>
<div class="crk-sidebar-scrim" data-crk-sidebar-scrim></div>
<aside id="crk-visual-sidebar" class="crk-sidebar" data-crk-sidebar>
<div class="crk-sidebar-brand">
<button class="crk-sidebar-close" type="button" data-crk-nav-close aria-label="Close navigation"></button>
<p class="eyebrow">Case visuals</p>
<h2>{{ package.case_title }}</h2>
</div>
<nav class="crk-sidebar-nav" aria-label="Visual export navigation">
<a class="crk-nav-link" href="{{ asset_prefix }}index.html"{% if current_page == "main" %} aria-current="page"{% endif %}>Main</a>
{% for group in package.nav_groups %}
<details class="crk-nav-group"{% if current_page in group.slugs %} open{% endif %}>
<summary><span>{{ group.title }}</span><span class="crk-nav-chevron" aria-hidden="true"></span></summary>
<div class="crk-nav-group-links">
{% for item in group.entries %}
<a class="crk-nav-link crk-nav-child" href="{{ asset_prefix }}consoles/{{ item.slug }}.html"{% if current_page == item.slug %} aria-current="page"{% endif %}>{{ item.title }}</a>
{% endfor %}
</div>
</details>
{% endfor %}
</nav>
<section class="crk-sidebar-section">
<h3>Export</h3>
<div class="crk-mode-toggle" data-crk-mode-toggle aria-label="Visual data mode">
<button type="button" data-crk-mode-option="public" aria-pressed="true">Public</button>
<button type="button" data-crk-mode-option="private" aria-pressed="false"{% if not package.contains_private_bundle %} disabled{% endif %}>Internal</button>
</div>
<p class="crk-mode-note" data-crk-mode-note>{% if package.contains_private_bundle %}Public data loads first. Internal mode switches to the bundled private review data.{% else %}Internal data was not bundled in this export.{% endif %}</p>
<p data-crk-scope>{{ package.scope }}</p>
<p>Generated {{ package.generated_at }}</p>
<p class="visual-warning"{% if not package.warnings %} hidden{% endif %} data-crk-warning>{{ package.warnings | join(" ") }}</p>
</section>
</aside>
