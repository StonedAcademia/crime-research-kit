<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Analysis chart index - {{ dash.case_title }}</title>
<style>{{ app_css | safe }}</style>
</head>
<body class="crk-report min-h-screen bg-slate-50 text-slate-900">
<header class="border-b border-slate-200 bg-white px-6 py-6">
<h1 class="text-2xl font-semibold">Analysis charts: {{ dash.case_title }}</h1>
<p class="crk-muted">Generated {{ dash.generated_at }}. Scope: {% if dash.include_private %}public and private/internal rows{% else %}public-export rows only{% endif %}.</p>
<p class="mt-3 max-w-3xl text-sm leading-6 text-slate-700">Open each chart in its own page for data-derived filters, hover/click inspection, keyboard focus, and table previews.</p>
</header>
<main class="mx-auto max-w-7xl px-6 py-6">
<div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
{% for page in dash.pages %}
<article class="rounded border border-slate-200 bg-white p-4">
<h2 class="text-lg font-semibold">{{ page.title }}</h2>
{% if page.summary %}<p class="mt-2 text-sm leading-6 text-slate-600">{{ page.summary }}</p>{% endif %}
<a class="mt-4 inline-block text-sm font-semibold text-blue-700 hover:underline" href="{{ page.slug }}.html">Open interactive chart</a>
</article>
{% endfor %}
</div>
</main>
<script>{{ app_js | safe }}</script>
</body>
</html>
