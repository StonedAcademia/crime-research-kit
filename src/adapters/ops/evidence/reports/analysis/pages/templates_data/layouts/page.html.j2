{% import "figures/svg.j2" as figures %}<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{ page.title }} - {{ page.case_title }}</title>
<style>{{ app_css | safe }}</style>
</head>
<body class="crk-report min-h-screen bg-slate-50 text-slate-900">
<header class="border-b border-slate-200 bg-white px-6 py-6">
<h1 class="text-2xl font-semibold">{{ page.title }}</h1>
<p class="crk-muted">{{ page.case_title }} &middot; generated {{ page.generated_at }}{% if page.include_private %} &middot; INTERNAL REVIEW (includes private records){% endif %}</p>
{% if page.summary %}<p class="mt-3 max-w-3xl text-sm leading-6 text-slate-700">{{ page.summary }}</p>{% endif %}
{% if page.filters %}<nav class="mt-4 flex flex-wrap gap-2">{% for term in page.filters %}<button type="button" class="crk-filter-btn" data-query="{{ term }}" aria-pressed="false">{{ term }}</button>{% endfor %}</nav>{% endif %}
</header>
<main class="mx-auto max-w-7xl px-6 py-6">
{% if page.figure %}<section class="overflow-x-auto rounded border border-slate-200 bg-white p-4">{{ figures.svg(page.figure) }}</section>{% elif page.legacy_figure_svg %}{{ page.legacy_figure_svg | safe }}{% endif %}
{% if page.table %}
<div class="crk-table-wrap mt-6"><table class="min-w-full border-collapse text-sm"><thead><tr>{% for col in page.table.columns %}<th class="border-b border-slate-200 bg-slate-100 px-3 py-2 text-left">{{ col.replace("_", " ").title() }}</th>{% endfor %}</tr></thead>
<tbody>{% for row in page.table.rows[:page.table.limit] %}<tr data-filterable="{{ row.values() | join(' ') }}">{% for col in page.table.columns %}<td class="border-b border-slate-100 px-3 py-2 align-top">{{ row.get(col, "") }}</td>{% endfor %}</tr>{% endfor %}</tbody></table></div>
{% if page.table.rows | length > page.table.limit %}<p class="crk-muted mt-2">Showing {{ page.table.limit }} of {{ page.table.rows | length }} rows.</p>{% endif %}
{% endif %}
{% for note in page.notes %}<p class="crk-muted mt-3">{{ note }}</p>{% endfor %}
</main>
<script>{{ app_js | safe }}</script>
</body>
</html>
